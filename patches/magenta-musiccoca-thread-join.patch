+MLXEngine::Impl::~Impl() {
+  // [mrt2-accompany local patch] Wait out any in-flight MusicCoCa encode
+  // before unload() frees the TFLite interpreters it is using. Worst case
+  // this blocks teardown for one encode (~seconds); the alternative was a
+  // host crash (mutex/interpreter use-after-free in the detached thread).
+  {
+    std::lock_guard<std::mutex> lk(musiccoca_thread_mutex_);
+    if (musiccoca_thread_.joinable())
+      musiccoca_thread_.join();
+  }
+  unload();
+}
 
